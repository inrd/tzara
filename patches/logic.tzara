# operations on pulse signals

+ pulse clock
= 200 clock@rate

+ seq8 seq
= 8 seq@length
= 1 seq@step1
= 0 seq@step2
= 0 seq@step3
= 1 seq@step4
= 0 seq@step5
= 0 seq@step6
= 1 seq@step7
= 1 seq@step8

> clock@out seq@clock

+ and trigs
> clock@out trigs@in1
> seq@out trigs@in2

+ sinosc osc
= 220 osc@freq
> trigs@out osc@reset

+ segment env
= 0.8 env@val1
= 0 env@val2
= 200 env@dur
> trigs@out env@clock

+ mult vca
> osc@out vca@in1
> env@out vca@in2

> vca@out _out_@l
> vca@out _out_@r


