! duration 32

+ pulse clock
= 200 clock@rate

+ count pos
> clock@out pos@clock
= 4 pos@max

# matrix indexes start from 0 so we normalize the counter value
+ sub column
> pos@out column@in1
= 1 column@in2

+ irandom row
> clock@out row@clock
= 0 row@min
= 2 row@max

+ matrix pattern 3 4 <m1.txt>
> row@out pattern@getrow
> column@out pattern@getcol

+ module blip <blip.tzara>
> pattern@out blip@note
= 120 blip@decay
> clock@out blip@trig

+ irandom row2
> clock@out row2@clock
= 0 row2@min
= 2 row2@max

# To access another location in the matrix during the same process frame 
# we need to use a separate mget node otherwise the 2nd matrix access 
# would shadow the first one (same as for var nodes)
+ mget p2 pattern
> row2@out p2@row
> column@out p2@col

+ add pat2
> p2@out pat2@in1
= 12 pat2@in2

+ module blip2 <blip.tzara>
> pat2@out blip2@note
= 120 blip2@decay
> clock@out blip2@trig


> blip@out _out_@l
> blip2@out _out_@r
