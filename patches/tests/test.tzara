# Test patch

# Primitive FM Oscillator

# Pitch modulator
+ phasor pitcher
= 0.01 pitcher@freq

# scale pitch modulation output
+ map pitchmod
= 0 pitchmod@imin
= 1 pitchmod@imax
= 110 pitchmod@omin
= 440 pitchmod@omax
> pitcher@out pitchmod@in

+ add modadd
> pitchmod@out modadd@in1

# Mod Osc
+ sinosc mod
= 200 mod@freq

+ mult fmdepth

# LFO
+ sinosc lfo
= 0.1 lfo@freq
+ mult lfoscale
> lfo@out lfoscale@in1
= 200 lfoscale@in2

+ add lforoute
> lfoscale@out lforoute@in1
= 200 lforoute@in2

# FM depth modulation
> mod@out fmdepth@in1
> lforoute@out fmdepth@in2
> fmdepth@out modadd@in2

# Carrier Osc
+ sinosc carrier
> modadd@out carrier@freq

# clip level
+ clip limiter
> carrier@out limiter@in
= -0.5 limiter@min
= 0.5 limiter@max

#  route to output
> limiter@out _out_@l
> limiter@out _out_@r

