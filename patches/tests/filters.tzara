
+ phasor ph
= 80 ph@freq

+ sub iph
= 1 iph@in1
> ph@out iph@in2

+ map saw
= 0 saw@imin
= 1 saw@imax
= -1 saw@omin
= 1 saw@omax
> iph@out saw@in

+ sinosc si
= 0.2 si@freq

+ map lfo
= -1 lfo@imin
= 1 lfo@imax
= 80 lfo@omin
= 1800 lfo@omax
> si@out lfo@in

+ smooth cut
> lfo@out cut@in
= 60 cut@dur

+ svf flt
> cut@out flt@cut
= 0.95 flt@res
> saw@out flt@in

+ tanh sat
> flt@lowpass sat@in

> sat@out _out_@l
> sat@out _out_@r

