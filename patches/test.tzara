# Test patch

# Primitive FM Oscillator

# Pitch modulator
+ phasor pitcher
= 0.01 pitcher@freq

+ mult pitcherdepth
> pitcher@out pitcherdepth@in1
= 440 pitcherdepth@in2

+ add pitchmod
= 110 pitchmod@in1
> pitcherdepth@out pitchmod@in2

+ add modadd
> pitchmod@out modadd@in1

# Mod Osc
+ sinosc mod
= 200 mod@freq

+ mult fmdepth

# LFO
+ sinosc lfo
= 0.1 lfo@freq
+ mult lfoscale
> lfo@out lfoscale@in1
= 200 lfoscale@in2

+ add lforoute
> lfoscale@out lforoute@in1
= 200 lforoute@in2

# FM depth modulation
> mod@out fmdepth@in1
> lforoute@out fmdepth@in2
> fmdepth@out modadd@in2

# Carrier Osc
+ sinosc carrier
> modadd@out carrier@freq

# scale level
+ mult amp
= 0.8 amp@in1
> carrier@out amp@in2

#  route to output
> amp@out out@l
> amp@out out@r

